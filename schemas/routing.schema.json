{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["clusters", "hops", "warnings"],
  "properties": {
    "clusters": {"type": "array", "items": {
      "type": "object", "required": ["district", "pois"],
      "properties": {
        "district": {"type": "string"},
        "is_base": {"type": "boolean"},
        "pois": {"type": "array", "items": {"type": "string"}}}}},
    "hops": {"type": "array", "items": {
      "type": "object", "required": ["from", "to", "mins", "flag"],
      "properties": {
        "from": {"type": "string"}, "to": {"type": "string"},
        "mode": {"type": "string"}, "mins": {"type": "number"},
        "flag": {"type": "string", "enum": ["ok", "far"]}}}},
    "warnings": {"type": "array", "items": {"type": "string"}}
  }
}
