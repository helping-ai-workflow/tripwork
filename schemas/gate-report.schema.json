{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "status",
    "checks",
    "failures"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "passed"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "distributable": {
      "type": "boolean",
      "description": "export-gate only: false marks a personal / non-distributable deliverable (e.g. google-sourced photos) — a clean terminal state, NOT a re-render-looping failure. A status==pass deliverable with distributable==false is complete-but-non-distributable. (P7)"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        }
      },
      "then": {
        "properties": {
          "failures": {
            "maxItems": 0
          },
          "checks": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
