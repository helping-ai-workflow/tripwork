{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "items",
    "daylight"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "hazard",
          "note",
          "severity",
          "sources"
        ],
        "properties": {
          "hazard": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "info",
              "advisory",
              "blocking"
            ]
          },
          "applies_to": {
            "type": "string"
          },
          "effective_window": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "contains": {
              "type": "object",
              "required": [
                "official"
              ],
              "properties": {
                "official": {
                  "const": true
                }
              }
            },
            "items": {
              "type": "object",
              "required": [
                "url",
                "official"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "pattern": "^https?://"
                },
                "official": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "daylight": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "district",
          "date",
          "sunset"
        ],
        "properties": {
          "district": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "sunset": {
            "type": "string"
          },
          "after_dark_arrival": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
