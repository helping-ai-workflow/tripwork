{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "slug",
    "dates",
    "members",
    "base",
    "must_do",
    "constraints",
    "preferences",
    "destination"
  ],
  "properties": {
    "slug": {
      "type": "string"
    },
    "dates": {
      "type": "object",
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "end": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      },
      "additionalProperties": false
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "base": {
      "type": "object",
      "required": [
        "name",
        "district"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "district": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "must_do": {
      "type": "array",
      "description": "Free-text required experiences/themes (e.g. '日月潭遊湖賞景'), NOT POI ids. itinerary-synthesis maps each to covering POI ids in itinerary.must_do_coverage; itinerary-gate verifies coverage. (P5)",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preferences": {
      "type": "object"
    },
    "transport": {
      "type": "string"
    },
    "budget": {
      "type": "object",
      "description": "Whole-trip budget cap. Scope = the full cost-rollup total: lodging (per-room × rooms × nights) + transport + daily incidentals. cost-rollup compares this against the grand total and stops on over-budget. (P6)",
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "daily_incidental": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "home_currency": {
      "type": "string"
    },
    "routing": {
      "type": "object",
      "properties": {
        "max_hop_mins": {
          "type": "number"
        },
        "region_radius_km": {
          "type": "number"
        },
        "max_single_drive_mins": {
          "type": "number"
        },
        "max_walk_mins": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "scheduling": {
      "type": "object",
      "properties": {
        "min_buffer_mins": {
          "type": "number"
        },
        "default_visit_mins": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "overnight_stops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "district",
          "nights"
        ],
        "properties": {
          "district": {
            "type": "string"
          },
          "nights": {
            "type": "integer",
            "minimum": 1
          },
          "leg_mode": {
            "type": "string"
          },
          "lodging": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "name_local": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "facility_needs": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "periodic": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "facility",
              "max_gap_nights"
            ],
            "properties": {
              "facility": {
                "type": "string"
              },
              "max_gap_nights": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "destination": {
      "type": "object",
      "required": [
        "country",
        "city",
        "local_lang"
      ],
      "properties": {
        "country": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "local_lang": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "airline": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
