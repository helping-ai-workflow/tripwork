{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["slug", "dates", "members", "base", "must_do", "constraints", "preferences"],
  "properties": {
    "slug": {"type": "string"},
    "dates": {
      "type": "object", "required": ["start", "end"],
      "properties": {"start": {"type": "string"}, "end": {"type": "string"}}
    },
    "members": {"type": "array", "items": {
      "type": "object", "required": ["name"],
      "properties": {"name": {"type": "string"}, "notes": {"type": "string"}}}},
    "base": {"type": "object", "required": ["name", "district"],
      "properties": {"name": {"type": "string"}, "district": {"type": "string"}}},
    "must_do": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "preferences": {"type": "object"},
    "transport": {"type": "string"},
    "budget": {"type": "object", "properties": {"amount": {"type": "number"}, "currency": {"type": "string"}}},
    "daily_incidental": {"type": "object", "properties": {"amount": {"type": "number"}, "currency": {"type": "string"}}},
    "home_currency": {"type": "string"},
    "routing": {"type": "object",
      "properties": {"max_hop_mins": {"type": "number"}, "region_radius_km": {"type": "number"}, "max_single_drive_mins": {"type": "number"}, "max_walk_mins": {"type": "number"}}},
    "scheduling": {"type": "object",
      "properties": {"min_buffer_mins": {"type": "number"}, "default_visit_mins": {"type": "number"}}},
    "overnight_stops": {"type": "array", "items": {
      "type": "object", "required": ["district", "nights"],
      "properties": {
        "district": {"type": "string"},
        "nights": {"type": "integer", "minimum": 1},
        "leg_mode": {"type": "string"},
        "lodging": {"type": "object", "required": ["name"],
          "properties": {"name": {"type": "string"}, "name_local": {"type": "string"}}}}}},
    "facility_needs": {"type": "object", "properties": {
      "required": {"type": "array", "items": {"type": "string"}},
      "periodic": {"type": "array", "items": {
        "type": "object", "required": ["facility", "max_gap_nights"],
        "properties": {"facility": {"type": "string"}, "max_gap_nights": {"type": "integer", "minimum": 1}}}}}}
  }
}
