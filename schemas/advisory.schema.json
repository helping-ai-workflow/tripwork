{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {"type": "array", "items": {
      "type": "object",
      "required": ["topic", "rule", "effective_date", "sources"],
      "properties": {
        "topic": {"type": "string"},
        "rule": {"type": "string"},
        "effective_date": {"type": "string"},
        "risk": {"type": "string", "enum": ["info", "restricted", "banned"]},
        "not_yet_in_effect": {"type": "boolean"},
        "sources": {"type": "array", "minItems": 1, "items": {
          "type": "object", "required": ["url", "official"],
          "properties": {"url": {"type": "string"}, "official": {"type": "boolean"}}}}
      }
    }}
  }
}
