{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["decisions"],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "flag", "subject", "decision", "decided_at"],
        "additionalProperties": false,
        "properties": {
          "stage": {"type": "string"},
          "flag": {"type": "string"},
          "subject": {"type": "string"},
          "question": {"type": "string"},
          "decision": {"type": "string"},
          "decided_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"}
        }
      }
    }
  }
}
