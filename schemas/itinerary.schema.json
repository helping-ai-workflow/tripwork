{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["days"],
  "additionalProperties": false,
  "properties": {
    "title": {"type": "string"},
    "checklist": {"type": "array", "items": {"type": "string"}},
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "rows"],
        "additionalProperties": false,
        "properties": {
          "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "label": {"type": "string"},
          "lodging": {"type": "string"},
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slot", "text"],
              "additionalProperties": false,
              "properties": {
                "time": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"},
                "slot": {"enum": ["meal", "activity", "visit", "move", "lodging"]},
                "poi_id": {"type": "string"},
                "text": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
